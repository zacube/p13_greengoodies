{% extends 'base.html.twig' %}

{% block title %}Mon compte{{ parent() }}{% endblock %}

{% block body %}
    <div class="account">
        <h1>Mon compte</h1>
        <div class="orders">
            <h2>Mes commandes</h2>
            <table>
                <tr>
                    <th>N°</th>
                    <th>Date</th>
                    <th class="colonne3">Prix</th>
                </tr>
                {% for item in purchaseList|reverse %}
                    <tr>
                        <td>{{ item.id }}</td>
                        <td>{{ item.date|date('d/m/Y') }}</td>
                        <td class="colonne3">{{ item.totalPrice|number_format(2, ',', ' ') }} €</td>
                    </tr>
                {% endfor %}
            </table>
        </div>
        <div class="api">
            <h2>Mon accès API</h2>
            <form method="post" action="{{ path('app_api_toggle') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('toggle-api') }}">
                <button type="submit" class="button">
                    {{ app.user.api ? 'Désactiver l\'accès API' :'Activer mon accès API' }}
                </button>
            </form>
        </div>
        <div class="api">
            <form action="{{ path('app_account_delete') }}" method="POST">
                <input type="hidden" name="_token" value="{{ csrf_token('account_delete') }}">
                <button type="submit" class="button"
                        onclick="return confirm('Êtes-vous sûr de vouloir supprimer votre compte ?')">Supprimer mon
                    compte
                </button>
            </form>
        </div>
    </div>
{% endblock %}
