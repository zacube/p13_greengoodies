{% extends 'base.html.twig' %}

{% block title %}Mon panier{{ parent() }}{% endblock %}

{% block body %}
    <div class="basket">
        <div>
            <h1>Mon panier</h1>
            {% if basket %}
                <form action="{{ path('app_basket_empty') }}" method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token('empty_basket') }}">
                    <button type="submit"><span>×</span> Vider le panier</button>
                </form>
            {% endif %}
            {% for item in basket %}
                <a href="{{ path('app_product', {slug: item.product.slug}) }}">
                    <div class="item">
                        <img src="{{ item.product.picture | imagine_filter('itembasket') }}"
                             alt="{{ item.product.name }}">
                        <div class="infos">
                            <h3>{{ item.product.name }}</h3>
                            <p class="qty">Quantité : {{ item.quantity }}</p>
                            <p class="price">{{ item.product.price|number_format(2, ',', ' ') }} €</p>
                        </div>
                    </div>
                </a>
            {% endfor %}
            <div class="total">
                <p>Total panier : <span>{{ totalPrice|number_format(2, ',', ' ') }} €</span></p>
                <p class="shipping">Frais de livraison : Offert</p>
            </div>
            {% if basket %}
                <form action="{{ path('app_basket_validate') }}" method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token('validate_basket') }}">
                    <button type="submit" class="button" onclick="return confirm('Êtes-vous sûr de vouloir valider votre panier ?')">
                        Valider la commande
                    </button>
                </form>
            {% endif %}
        </div>
    </div>
{% endblock %}
