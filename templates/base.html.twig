<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Green Goodies, produits durables et éthiques pour une consommation responsable. Hygiène, beauté, accessoires, boissons, prêt-à-porter">
    <title>{% block title %} - Green Goodies{% endblock %}</title>
    <link rel="icon" type="image/png" href="/images/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <link rel="shortcut icon" href="/images/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}

</head>
<body>
<div class="wrapper">
    <header>
        <a href="{{ path('app_index') }}" class="logo">
            <img src="{{ asset('images/logo.svg') }}" alt="logo GreenGoodies">
        </a>
        <nav>
            <a href="{{ path('app_index') }}" class="">Nos produits</a>
            <div>
                <a href="{{ path('app_basket') }}" class="">Panier</a>
                <a href="{{ path('app_account') }}" class="">Commandes</a>
                <a href="{{ path('app_auth_login') }}" class="">Connexion</a>
            </div>
        </nav>
    </header>
    {% block body %}{% endblock %}
</div>
<footer>
    <div>
        <a href="">CGU</a>
        <a href="">© GreenGoodies - 2024</a>
    </div>
</footer>
</body>
</html>
