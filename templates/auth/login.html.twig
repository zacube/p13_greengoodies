{% extends 'base.html.twig' %}

{% block title %}Connexion{{ parent() }}{% endblock %}

{% block body %}
    <div class="login">
        <img src="{{ '/images/conviction.jpg' | imagine_filter('connection') }}" alt="">
        <div class="form">
            <h1>Connexion</h1>
            <form action="index.php?action=connectUser" method="post">
                <label for="login">Adresse mail</label>
                <input type="text" name="login" id="login" required="">
                <label for="password">Mot de passe</label>
                <input type="password" name="password" id="password" required="">
                <button class="mainButton">Se connecter</button>
            </form>
            <p><a href="index.php?action=registrationForm">Pas encore de compte ? S’inscrire</a></p>
        </div>
    </div>
{% endblock %}
