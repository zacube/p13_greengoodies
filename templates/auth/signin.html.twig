{% extends 'base.html.twig' %}

{% block title %}Inscription{{ parent() }}{% endblock %}

{% block body %}
    <div class="signin">
        <img src="{{ '/images/inscription.jpg' | imagine_filter('connection') }}" alt="">
        <div class="form">
            <h1>Inscription</h1>
            <p class="subtitle">Tous les champs sont obligatoires.</p>
            <form action="index.php?action=connectUser" method="post">
                <label for="name">Nom</label>
                <input type="text" name="name" id="name" required="">
                <label for="firstname">Prénom</label>
                <input type="text" name="firstname" id="firstname" required="">
                <label for="login">Adresse mail</label>
                <input type="text" name="login" id="login" required="">
                <label for="password">Mot de passe</label>
                <input type="password" name="password" id="password" required="">
                <label for="password2">Confirmation mot de passe</label>
                <input type="password" name="password2" id="password2" required="">
                <input type="checkbox" id="cgu" name="cgu" value="Bike">
                <label for="vehicle1">J’accepte les CGU de GreenGoodies</label><br>
                <button class="mainButton">Se connecter</button>
            </form>
            <p><a href="index.php?action=registrationForm">Pas encore de compte ? S’inscrire</a></p>
        </div>
    </div>
{% endblock %}
