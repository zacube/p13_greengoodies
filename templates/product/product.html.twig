{% extends 'base.html.twig' %}

{% block title %}Produit{{ parent() }}{% endblock %}

{% block body %}
    <div class="product">
        <img src="{{ product.picture | imagine_filter('product') }}" alt="{{ product.name }}">
        <div class="info">
            <div class="details">
                <h1>{{ product.name }}</h1>
                <p class="price">{{ product.price }} €</p>
                <h4>Description</h4>
                <p>{{ product.longDesc}}</p>
            </div>
            <a href="">Ajouter au panier</a>
        </div>
    </div>
{% endblock %}
